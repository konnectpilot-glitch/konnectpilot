import Layout from "@/components/layout";
import { useEffect, useState } from "react";
import { useAuth } from "@clerk/react";
import { useQuery, useMutation, useQueryClient } from "@tanstack/react-query";
import {
  Inbox,
  Facebook,
  Instagram,
  Linkedin,
  Wand2,
  Loader2,
  Copy,
  Check,
  Trash2,
  CheckCircle2,
  RefreshCw,
} from "lucide-react";
import { toast } from "sonner";
import { useWorkspace } from "@/lib/workspaceContext";
import { friendlyError } from "@/lib/friendly-error";
import EmptyState from "@/components/empty-state";

// Audience comment inbox — surfaces every active (unreplied, undismissed)
// comment across the workspace's brands. Each row shows the comment + the
// post it's attached to + an inline AI Reply Drafter button.
//
// On reply: click "AI draft" → fetches 3 brand-voice replies → user copies
// the one they want → click "Mark replied" (the actual send-to-FB/IG would
// require a separate publish-back step which needs Meta scope work — for
// now we let the user paste into the platform UI, then mark the comment
// as handled here).

interface InboxComment {
  id: number;
  brandId: number;
  brandName?: string;
  postId: number;
  platform: string;
  authorName: string | null;
  content: string;
  platformCreatedAt: string | null;
  fetchedAt: string;
  postContent: string | null;
  postImageUrl: string | null;
}

interface Draft {
  tone: string;
  reply: string;
}

function PlatformIcon({ platform }: { platform: string }) {
  if (platform === "facebook") return <Facebook className="w-3.5 h-3.5 text-blue-600" />;
  if (platform === "instagram") return <Instagram className="w-3.5 h-3.5 text-pink-600" />;
  if (platform === "linkedin") return <Linkedin className="w-3.5 h-3.5 text-blue-700" />;
  return null;
}

export default function InboxPage() {
  const { getToken } = useAuth();
  const { activeWorkspace } = useWorkspace();
  const qc = useQueryClient();

  async function authedHeaders(): Promise<HeadersInit> {
    const t = await getToken();
    return {
      "Content-Type": "application/json",
      ...(t ? { Authorization: `Bearer ${t}` } : {}),
      ...(activeWorkspace ? { "X-Workspace-Id": String(activeWorkspace.id) } : {}),
    };
  }

  const { data, isLoading, refetch, isFetching } = useQuery<{ comments: InboxComment[]; unrepliedCount: number }>({
    queryKey: ["audience-comments-inbox", activeWorkspace?.id],
    queryFn: async () => {
      const headers = await authedHeaders();
      const res = await fetch("/api/comments/inbox", { credentials: "include", headers });
      if (!res.ok) throw new Error("Couldn't load inbox");
      return res.json();
    },
  });

  const dismiss = useMutation({
    mutationFn: async (id: number) => {
      const headers = await authedHeaders();
      const res = await fetch(`/api/comments/${id}/dismiss`, { method: "POST", credentials: "include", headers });
      if (!res.ok) throw new Error("Dismiss failed");
    },
    onSuccess: () => qc.invalidateQueries({ queryKey: ["audience-comments-inbox"] }),
    onError: (e: any) => toast.error(friendlyError(e, "Couldn't dismiss.")),
  });

  const markReplied = useMutation({
    mutationFn: async ({ id, replyContent }: { id: number; replyContent?: string }) => {
      const headers = await authedHeaders();
      const res = await fetch(`/api/comments/${id}/mark-replied`, {
        method: "POST",
        credentials: "include",
        headers,
        body: JSON.stringify({ replyContent }),
      });
      if (!res.ok) throw new Error("Mark-replied failed");
    },
    onSuccess: () => qc.invalidateQueries({ queryKey: ["audience-comments-inbox"] }),
    onError: (e: any) => toast.error(friendlyError(e, "Couldn't mark as replied.")),
  });

  return (
    <Layout>
      <div className="p-6 max-w-4xl mx-auto space-y-6">
        <div className="flex items-start justify-between gap-3">
          <div>
            <div className="flex items-center gap-2 mb-1">
              <Inbox className="w-5 h-5 text-primary" />
              <h1 className="text-2xl font-bold text-foreground">Comment inbox</h1>
              <span className="text-[10px] uppercase tracking-wider font-bold text-primary bg-primary/10 px-1.5 py-0.5 rounded">Live</span>
            </div>
            <p className="text-sm text-muted-foreground">
              Audience comments from your published posts. AI drafts brand-voice replies on demand.
            </p>
          </div>
          <button
            onClick={() => refetch()}
            disabled={isFetching}
            className="flex items-center gap-1.5 text-sm font-medium border border-border px-3 py-2 rounded-lg hover:bg-secondary disabled:opacity-60"
          >
            {isFetching ? <Loader2 className="w-3.5 h-3.5 animate-spin" /> : <RefreshCw className="w-3.5 h-3.5" />}
            Refresh
          </button>
        </div>

        {isLoading ? (
          <div className="space-y-3">
            {[1, 2, 3].map((i) => <div key={i} className="h-32 bg-muted/40 rounded-xl animate-pulse" />)}
          </div>
        ) : (data?.comments.length ?? 0) === 0 ? (
          <div className="bg-card border border-border rounded-xl">
            <EmptyState
              icon={Inbox}
              title="Inbox is empty"
              description="When someone comments on one of your published Facebook or Instagram posts, it'll land here. The collector polls every 10 minutes."
              primaryCta={{ label: "Refresh now", onClick: () => refetch(), icon: RefreshCw }}
            />
          </div>
        ) : (
          <div className="space-y-3">
            {data?.comments.map((c) => (
              <CommentCard
                key={c.id}
                comment={c}
                onDismiss={() => dismiss.mutate(c.id)}
                onMarkReplied={(replyContent) => markReplied.mutate({ id: c.id, replyContent })}
                authedHeaders={authedHeaders}
              />
            ))}
          </div>
        )}
      </div>
    </Layout>
  );
}

// One row per comment — shows the post + the comment + an inline AI draft
// generator. Reply drafts are lazy (fetched on click) so the inbox loads
// instantly even with 50 active comments.
function CommentCard({
  comment,
  onDismiss,
  onMarkReplied,
  authedHeaders,
}: {
  comment: InboxComment;
  onDismiss: () => void;
  onMarkReplied: (replyContent?: string) => void;
  authedHeaders: () => Promise<HeadersInit>;
}) {
  const [drafts, setDrafts] = useState<Draft[]>([]);
  const [drafting, setDrafting] = useState(false);
  const [copiedIdx, setCopiedIdx] = useState<number | null>(null);
  const [lastCopied, setLastCopied] = useState<string | null>(null);

  async function generateDrafts() {
    if (drafting) return;
    setDrafting(true);
    try {
      const headers = await authedHeaders();
      const res = await fetch("/api/reply-drafter/draft", {
        method: "POST",
        credentials: "include",
        headers,
        body: JSON.stringify({
          brandId: comment.brandId,
          postContent: comment.postContent ?? "",
          commentText: comment.content,
          commenterName: comment.authorName,
          platform: comment.platform,
        }),
      });
      const json = await res.json();
      if (!res.ok) throw new Error(json?.error ?? "Drafting failed");
      setDrafts(json.drafts ?? []);
    } catch (err: any) {
      toast.error(friendlyError(err, "Couldn't draft replies."));
    } finally {
      setDrafting(false);
    }
  }

  function copyAndTrack(idx: number, text: string) {
    navigator.clipboard.writeText(text);
    setCopiedIdx(idx);
    setLastCopied(text);
    setTimeout(() => setCopiedIdx(null), 1500);
    toast.success("Copied — paste into the platform, then hit Mark replied");
  }

  return (
    <div className="bg-card border border-border rounded-xl p-4">
      <div className="flex items-start gap-3 mb-3">
        {/* Post preview thumbnail — anchors which post this comment is on */}
        {comment.postImageUrl ? (
          <img src={comment.postImageUrl} alt="" className="w-12 h-12 rounded-md object-cover border border-border flex-shrink-0" />
        ) : (
          <div className="w-12 h-12 rounded-md bg-gradient-to-br from-primary/10 to-purple-500/10 flex-shrink-0" />
        )}
        <div className="flex-1 min-w-0">
          <div className="flex items-center gap-2 text-[11px] text-muted-foreground mb-0.5">
            <PlatformIcon platform={comment.platform} />
            <span className="capitalize">{comment.platform}</span>
            <span>·</span>
            <span className="truncate">{comment.brandName}</span>
            {comment.platformCreatedAt && (
              <>
                <span>·</span>
                <span>{new Date(comment.platformCreatedAt).toLocaleString()}</span>
              </>
            )}
          </div>
          {comment.postContent && (
            <p className="text-xs text-muted-foreground line-clamp-1 italic">on: {comment.postContent}</p>
          )}
        </div>
      </div>

      {/* The comment */}
      <div className="bg-secondary/50 rounded-lg p-3 mb-3">
        <p className="text-xs font-medium text-foreground mb-1">
          {comment.authorName ?? "Someone"} said:
        </p>
        <p className="text-sm text-foreground leading-snug">{comment.content}</p>
      </div>

      {/* Drafts */}
      {drafts.length > 0 && (
        <div className="space-y-2 mb-3">
          {drafts.map((d, i) => (
            <div key={i} className="border border-border rounded-lg p-3 bg-background">
              <div className="flex items-center justify-between mb-1.5">
                <span className="text-[10px] uppercase tracking-wider font-bold text-muted-foreground">{d.tone}</span>
                <button
                  onClick={() => copyAndTrack(i, d.reply)}
                  className="flex items-center gap-1 text-[11px] font-medium text-primary hover:underline"
                >
                  {copiedIdx === i ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                  {copiedIdx === i ? "Copied" : "Copy"}
                </button>
              </div>
              <p className="text-sm text-foreground whitespace-pre-wrap leading-relaxed">{d.reply}</p>
            </div>
          ))}
        </div>
      )}

      {/* Actions */}
      <div className="flex items-center gap-1.5 flex-wrap">
        <button
          onClick={generateDrafts}
          disabled={drafting}
          className="flex items-center gap-1.5 text-xs font-semibold bg-primary text-primary-foreground px-2.5 py-1.5 rounded-md hover:opacity-90 disabled:opacity-60"
        >
          {drafting ? <Loader2 className="w-3.5 h-3.5 animate-spin" /> : <Wand2 className="w-3.5 h-3.5" />}
          {drafts.length > 0 ? "Re-draft" : "AI draft replies"}
        </button>
        <div className="flex-1" />
        <button
          onClick={() => onMarkReplied(lastCopied ?? undefined)}
          className="flex items-center gap-1.5 text-xs font-semibold border border-border text-foreground px-2.5 py-1.5 rounded-md hover:bg-secondary"
        >
          <CheckCircle2 className="w-3.5 h-3.5" />
          Mark replied
        </button>
        <button
          onClick={onDismiss}
          className="flex items-center gap-1 text-xs font-medium text-muted-foreground hover:text-rose-600 px-2 py-1.5 rounded-md hover:bg-secondary"
          title="Dismiss (spam / not relevant)"
        >
          <Trash2 className="w-3.5 h-3.5" />
          Dismiss
        </button>
      </div>
    </div>
  );
}
